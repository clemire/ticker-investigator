# Server logging (INFO includes per-article news_drop_* lines)
LOG_LEVEL=INFO

# App settings
DEFAULT_THRESHOLD_PCT=2.0
DEFAULT_NEWS_LIMIT=10
REQUEST_TIMEOUT_SECONDS=15.0
UPSTREAM_RETRY_ATTEMPTS=3
UPSTREAM_RETRY_BACKOFF_SECONDS=1.0
# Post-fetch relevance (0..1); articles below this score are dropped.
NEWS_RELEVANCE_THRESHOLD=0.42
# Raw articles per provider ≈ news_limit * multiplier before filtering.
NEWS_FETCH_POOL_MULTIPLIER=4
# Thread pool size for parallel news provider calls (max 5 sources).
NEWS_FETCH_PARALLEL=5

# News provider keys
NEWSAPI_API_KEY=
GNEWS_API_KEY=
EXA_API_KEY=

# OpenAI-compatible API (terminal chat + batched article classification)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
# Set to false to keep keyword-only categories (no extra API calls)
NEWS_LLM_CLASSIFIER_ENABLED=true
NEWS_LLM_MODEL=gpt-4o-mini
NEWS_LLM_BATCH_SIZE=12
NEWS_LLM_TIMEOUT_SECONDS=45
NEWS_LLM_MAX_PARALLEL=3
# LLM: top 5 competitor names appended to NewsAPI/GNews/Exa/Jina search (requires OPENAI_API_KEY)
NEWS_COMPETITOR_LLM_ENABLED=true
NEWS_COMPETITOR_LLM_TIMEOUT_SECONDS=20
